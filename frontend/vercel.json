{
  "version": 2,
  "functions": {
    "api/*.py": {
      "runtime": "vercel-python@3.0.0",
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/health", "dest": "/api/health.py" },
    { "src": "/api/upload", "dest": "/api/upload.py" },
    { "src": "/api/process", "dest": "/api/process.py" },
    { "src": "/api/preview", "dest": "/api/preview.py" },
    { "src": "/api/orders", "dest": "/api/orders.py" }
  ]
}
